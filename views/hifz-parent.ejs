<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Parent Portal | Student Progress</title>
    <!-- Tailwind for layout, custom CSS for the Smooth Design System -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/hifz-parent.css">
</head>
<body>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="glass-card entrance-anim">
        <!-- Header Section -->
        <div class="portal-icon">
            <i class="fa-solid fa-graduation-cap"></i>
        </div>
        
        <h1 class="text-2xl md:text-3xl font-bold text-slate-800 tracking-tight mb-1">
            Student Progress Portal
        </h1>
        <p class="text-slate-500 mb-8 font-medium">Enter details to continue</p>

        <!-- EJS Error Handling -->
       <% if (error) { %>
  <div class="error-box">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
  </div>
<% } %>

        <!-- Login Form -->
        <form action="/hifz/parent" method="POST">
            <div class="form-group">
                <label for="studentName" class="label-smooth">Student Name</label>
                <input 
                    type="text" 
                    id="studentName" 
                    name="name" 
                    class="input-smooth" 
                    placeholder="Enter full name"
                    required
                >
            </div>

            <div class="form-group">
                <label for="dob" class="label-smooth">Date of Birth</label>
                <input 
                    type="date" 
                    id="dob" 
                    name="dob" 
                    class="input-smooth" 
                    required
                >
            </div>

            <button type="submit" class="btn-primary-smooth mt-4">
                <span>View Progress</span>
                <i class="fa-solid fa-arrow-right-long"></i>
            </button>
        </form>

        <footer class="mt-8 pt-6 border-t border-slate-200/50 text-center">
            <p class="text-xs text-slate-400 font-medium">
                &copy; 2026 Gazzali Academy Portal. All rights reserved.
            </p>
        </footer>
    </div>

    <script>
        // Prevent accidental double submits and add a little "loading" feel
        document.querySelector('form').addEventListener('submit', function(e) {
            const btn = this.querySelector('button');
            const icon = btn.querySelector('i');
            
            btn.style.pointerEvents = 'none';
            btn.style.opacity = '0.7';
            icon.className = 'fa-solid fa-circle-notch fa-spin';
        });
    </script>
</body>
</html>