<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imam Gazzali Academy | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="dashboard-container">

        <!-- Top Navigation Bar -->
        <nav class="top-navbar">
            <div class="logo-section">
                <img src="/images/logo1.png" 
                     alt="Imam Gazzali Academy Logo" 
                     class="academy-logo">
                <div class="academy-name">
                    <h1>Imam Gazzali Academy</h1>
                    <p>Student Management Portal</p>
                </div>
            </div>
            
            <div class="nav-actions">
                <a href="/students" class="nav-link">
                    <span class="icon">👥</span>
                    Students
                </a>
                <a href="/students/new" class="btn-primary">
                    <span class="plus">+</span> Add New Student
                </a>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            
            <div class="welcome-section">
                <h1>Welcome back, Admin! 👋</h1>
                <p>Good to see you at Imam Gazzali Academy. Here's what's happening today.</p>
            </div>

            <!-- Quick Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon bg-blue">👥</div>
                    <div class="stat-info">
                        <h3>Total Students</h3>
                        <div class="stat-number"><%= totalStudents %></div>
                    </div>
                </div>
                
                <!-- <div class="stat-card">
                    <div class="stat-icon bg-green">📅</div>
                    <div class="stat-info">
                        <h3>New Admissions</h3>
                        <div class="stat-number">18</div>
                        <p class="stat-trend positive">This academic year</p>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon bg-purple">🏫</div>
                    <div class="stat-info">
                        <h3>Active Classes</h3>
                        <div class="stat-number">14</div>
                        <p class="stat-trend">Grade 1 – Grade 12</p>
                    </div>
                </div>
            </div> -->

            <!-- Action Cards -->
            <div class="dashboard-grid">
                
                <a href="/students" class="dash-card glass-card">
                    <div class="card-icon-wrapper bg-indigo">
                        <span class="card-icon">👥</span>
                    </div>
                    <div class="card-content">
                        <h3>View All Students</h3>
                        <p>Browse the complete student directory, search, edit and manage records.</p>
                        <span class="card-cta">Open Directory →</span>
                    </div>
                </a>

                <a href="/students/new" class="dash-card glass-card">
                    <div class="card-icon-wrapper bg-teal">
                        <span class="card-icon">➕</span>
                    </div>
                    <div class="card-content">
                        <h3>Add New Student</h3>
                        <p>Register a new admission and add student details to the academy database.</p>
                        <span class="card-cta">Start Admission →</span>
                    </div>
                </a>

            </div>

        </main>

        <!-- Footer -->
        <footer class="dash-footer">
            <p>&copy; 2026 Imam Gazzali Academy • Student Management System</p>
            <!-- <p class="footer-link">Made with ❤️ for Imam Gazzali Academy</p> -->
        </footer>

    </div>

</body>
</html>