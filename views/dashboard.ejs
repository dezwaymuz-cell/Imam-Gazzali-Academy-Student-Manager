<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imam Gazzali Academy | Dashboard</title>
    <!-- Google Fonts: Plus Jakarta Sans -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    
</head>
<body>

    <!-- Blurred Background Orbs from Design Language PDF -->
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    <div class="dashboard-container">
        
        <!-- Navigation -->
        <nav class="top-navbar">
            <div class="logo-section">
                <img src="/images/logo1.png" alt="Logo" class="academy-logo" onerror="this.src='https://ui-avatars.com/api/?name=IGA&background=4F46E5&color=fff'">
                <div class="academy-name">
                    <h1>Imam Gazzali</h1>
                    <p>Academy Portal</p>
                </div>
            </div>
            
            <div class="nav-actions">
                <a href="/students" class="btn btn-ghost">
                    <span>👥</span> Students
                </a>
                <a href="/students/new" class="btn btn-primary">
                    <span>+</span> Add Student
                </a>
                
                <!-- Smooth Logout Button -->
                <form action="/logout" method="GET" style="display: inline;">
                    <button type="submit" class="btn btn-logout">
                        <span>Logout</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                        </svg>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <div class="welcome-header">
                <h2>السَّلَامُ عَلَيْكُمْ 👋</h2>
                <p>Welcome to your central management hub. Monitor student performance, manage enrollments, and ensure academic quality from one smooth interface.</p>
            </div>

            <!-- Dynamic Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <span class="stat-label">Total Enrollment</span>
                    <div class="stat-value"><%= totalStudents %></div>
                </div>
                
                <!-- <div class="stat-card">
                    <span class="stat-label">Active Term</span>
                    <div class="stat-value" style="font-size: 1.8rem; padding-top: 10px;">Spring 2026</div>
                </div> -->
                
                <div class="stat-card">
                    <span class="stat-label">Portal Status</span>
                    <div class="stat-value" style="font-size: 1.8rem; color: #10B981; padding-top: 10px;">Secure ●</div>
                </div>
            </div>

            <!-- Action Cards -->
            <div class="action-grid">
                <a href="/students" class="action-card">
                    <div class="icon-circle">📂</div>
                    <h3>Student Directory</h3>
                    <p>Review comprehensive details for every student, including attendance, grades, and emergency contacts.</p>
                    <span class="action-link">Explore Records &rarr;</span>
                </a>

                <a href="/students/new" class="action-card">
                    <div class="icon-circle">📝</div>
                    <h3>New Enrollment</h3>
                    <p>Initiate the registration process for new candidates with our streamlined data entry system.</p>
                    <span class="action-link">Start Registration &rarr;</span>
                </a>
            </div>
        </main>

        <footer class="dash-footer">
            <p>&copy; 2026 Imam Gazzali Academy • Professional Education Management</p>
        </footer>
    </div>

</body>
</html>