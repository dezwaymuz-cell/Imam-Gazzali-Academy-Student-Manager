<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imam Gazzali Academy | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Background Orbs -->
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    <div class="dashboard-container">
        
        <!-- Navigation Bar -->
        <nav class="top-navbar">
            <a href="/" class="logo-section">
                <img src="/images/logo1.png" alt="Academy Logo" class="academy-logo" onerror="this.src='https://ui-avatars.com/api/?name=IGA&background=4F46E5&color=fff'">
                <div class="academy-name">
                    <h1>Imam Gazzali</h1>
                    <p>Student Portal</p>
                </div>
            </a>
            
            <div class="nav-actions">
                <a href="/students" class="btn btn-ghost">
                    <span>👥</span> Students
                </a>
                <a href="/students/new" class="btn btn-primary">
                    <span>+</span> Add New
                </a>
                
                <form action="/logout" method="GET" style="display: contents;">
                    <button type="submit" class="btn btn-logout" title="Exit Portal">
                        <span>Logout</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                        </svg>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Workspace -->
        <main class="main-content">
            <div class="welcome-header">
                <h2>Assalamu Alaikum, Admin! 👋</h2>
                <p>Monitor your academy's academic pulse. From individual student tracking to high-level enrollment trends, manage everything with effortless precision.</p>
            </div>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <div class="stat-card">
                    <span class="stat-label">Total Enrollment</span>
                    <div class="stat-value"><%= totalStudents %></div>
                </div>
                
                <div class="stat-card">
                    <span class="stat-label">Active Term</span>
                    <div class="stat-value" style="font-size: clamp(1.5rem, 3vw, 2.2rem); margin-top: 10px;">Spring '26</div>
                </div>
                
                <div class="stat-card">
                    <span class="stat-label">Portal Integrity</span>
                    <div class="stat-value" style="font-size: clamp(1.5rem, 3vw, 2.2rem); color: #10B981; margin-top: 10px;">Secure ●</div>
                </div>
            </div>

            <!-- Dashboard Action Cards -->
            <div class="action-grid">
                <!-- Student Directory -->
                <a href="/students" class="action-card">
                    <div class="icon-box">📂</div>
                    <h3>Student Directory</h3>
                    <p>Detailed insight into student profiles, academic progress reports, and historical data points for informed decision making.</p>
                    <span class="action-link">Open Records &rarr;</span>
                </a>

                <!-- Enrollment Entry -->
                <a href="/students/new" class="action-card">
                    <div class="icon-box">📝</div>
                    <h3>Enrollment Entry</h3>
                    <p>Add new students to the Academy's official roster using our optimized, validation-ready registration interface.</p>
                    <span class="action-link">Register Student &rarr;</span>
                </a>

                <!-- ==================== HIFZ → COMING SOON ==================== -->
                <!-- You can easily change text, icon or modal content below -->
                <div class="action-card coming-soon-card" onclick="showComingSoonModal()">
                    <div class="icon-box">📖</div>
                    <h3>HIFZ</h3>
                    
                    <!-- Coming Soon Badge -->
                    <div class="coming-soon-badge">Coming Soon</div>
                    
                    <p>Dedicated tracking and management system for Hifz students. Monitor memorization progress, daily lessons (Padam), Sabk Juz, and Murajah with structured records.</p>
                    <span class="action-link coming-soon-link">Coming Soon &rarr;</span>
                </div>


                
                <!-- ============================================================ -->
                 <!-- <a href="/hifz" class="action-card">
                    <div class="icon-box">📖</div>
                    <h3>HIFZ</h3>
                    <p>Dedicated tracking and management system for Hifz students. Monitor memorization progress, daily lessons (Padam), Sabk Juz, and Murajah with structured records.</p>
                    <span class="action-link">View Hifz Students &rarr;</span>
                </a>     -->
            </div>
        </main>

        <footer class="dash-footer">
            <p>&copy; 2026 Imam Gazzali Academy • Professional Management Suite</p>
        </footer>
    </div>

    <!-- ==================== COMING SOON MODAL ==================== -->
    <!-- Fully smooth glass modal – easy to customize -->
    <div id="comingSoonModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-body">
                <div class="modal-icon">📖✨</div>
                <h2>HIFZ Section</h2>
                <div class="modal-status">Coming Soon</div>
                <p class="modal-text">
                    Advanced Hifz tracking, Padam, Sabk, Murajah and progress analytics<br>
                    are being prepared with utmost care.
                </p>
                <p class="modal-subtext">Stay tuned — launching very soon!</p>
                
                <button onclick="hideComingSoonModal()" class="btn btn-primary modal-close-btn">
                    Got it, thanks!
                </button>
            </div>
        </div>
    </div>
    <!-- ======================================================== -->

    <script>
        // Show Coming Soon Modal (super smooth)
        function showComingSoonModal() {
            const modal = document.getElementById('comingSoonModal');
            modal.classList.add('active');
        }

        // Hide Coming Soon Modal
        function hideComingSoonModal() {
            const modal = document.getElementById('comingSoonModal');
            modal.classList.remove('active');
        }

        // Optional: Close modal when clicking outside
        document.getElementById('comingSoonModal').addEventListener('click', function(e) {
            if (e.target === this) hideComingSoonModal();
        });
    </script>
</body>
</html>