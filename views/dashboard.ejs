<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imam Gazzali Academy | Dashboard</title>
    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="stylesheet" href="/css/style.css">

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <!-- 2. Visual Elements: Background Depth Orbs -->
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    <div class="dashboard-container">
        
        <!-- Navigation Bar -->
        <nav class="top-navbar">
            <a href="/" class="logo-section">
                <img src="/images/logo1.png" alt="Academy Logo" class="academy-logo" onerror="this.src='https://ui-avatars.com/api/?name=IGA&background=4F46E5&color=fff'">
                <div class="academy-name">
                    <h1>Imam Gazzali</h1>
                    <p>Student Portal</p>
                </div>
            </a>
            
            <div class="nav-actions">
                <a href="/students" class="btn btn-ghost">
                    <span>👥</span> Students
                </a>
                <a href="/students/new" class="btn btn-primary">
                    <span>+</span> Add New
                </a>
                
                <!-- 3. Interactions: Smooth Logout Button -->
                <form action="/logout" method="GET" style="display: contents;">
                    <button type="submit" class="btn btn-logout" title="Exit Portal">
                        <span>Logout</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                        </svg>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Workspace -->
        <main class="main-content">
            <div class="welcome-header">
                <h2>Assalamu Alaikum, Admin! 👋</h2>
                <p>Monitor your academy's academic pulse. From individual student tracking to high-level enrollment trends, manage everything with effortless precision.</p>
            </div>

            <!-- 4. Fluid Stats Grid -->
            <div class="stats-grid">
                <div class="stat-card">
                    <span class="stat-label">Total Enrollment</span>
                    <div class="stat-value"><%= totalStudents %></div>
                </div>
                
                <div class="stat-card">
                    <span class="stat-label">Active Term</span>
                    <div class="stat-value" style="font-size: clamp(1.5rem, 3vw, 2.2rem); margin-top: 10px;">Spring '26</div>
                </div>
                
                <div class="stat-card">
                    <span class="stat-label">Portal Integrity</span>
                    <div class="stat-value" style="font-size: clamp(1.5rem, 3vw, 2.2rem); color: #10B981; margin-top: 10px;">Secure ●</div>
                </div>
            </div>

            <!-- Dashboard Action Cards -->
            <div class="action-grid">
                <a href="/students" class="action-card">
                    <div class="icon-box">📂</div>
                    <h3>Student Directory</h3>
                    <p>Detailed insight into student profiles, academic progress reports, and historical data points for informed decision making.</p>
                    <span class="action-link">Open Records &rarr;</span>
                </a>

                <a href="/students/new" class="action-card">
                    <div class="icon-box">📝</div>
                    <h3>Enrollment Entry</h3>
                    <p>Add new students to the Academy's official roster using our optimized, validation-ready registration interface.</p>
                    <span class="action-link">Register Student &rarr;</span>
                </a>
            </div>
        </main>

        <footer class="dash-footer">
            <p>&copy; 2026 Imam Gazzali Academy • Professional Management Suite</p>
        </footer>
    </div>

</body>
</html>