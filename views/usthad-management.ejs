<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usthad Management | Imam Gazzali Academy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #4F46E5;
            --surface-bg: #F8FAFC;
            --glass-bg: rgba(255, 255, 255, 0.8);
            --text-heading: #1E293B;
            --text-sub: #64748B;
            --main-radius: 2rem;
            --component-radius: 1.25rem;
            --ease-smooth: cubic-bezier(0.16, 1, 0.3, 1);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--surface-bg);
            color: var(--text-heading);
            min-height: 100vh;
        }

        .bg-orb {
            position: fixed;
            width: 45vw; height: 45vw;
            border-radius: 50%;
            filter: blur(100px);
            z-index: -1;
            opacity: 0.5;
        }
        .orb-1 { top: -10vh; right: -10vw; background: #E0E7FF; }
        .orb-2 { bottom: -10vh; left: -10vw; background: #EFF6FF; }

        .dashboard-wrapper {
            max-width: 1200px;
            margin: 2rem auto;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: var(--main-radius);
            border: 1px solid rgba(255, 255, 255, 0.7);
            padding: clamp(1.5rem, 4vw, 3rem);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
        }

        .usthad-row {
            transition: all 0.3s var(--ease-smooth);
            border-bottom: 1px solid #F1F5F9;
        }
        .usthad-row:hover {
            background: rgba(248, 250, 252, 0.8);
        }

        .pass-container {
            font-family: 'Courier New', Courier, monospace;
            letter-spacing: 1px;
        }

        /* Modal & Animations */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 50;
            opacity: 0;
            transition: opacity 0.3s var(--ease-smooth);
        }
        .modal-overlay.active { 
            display: flex; 
            opacity: 1;
        }
        
        .modal-content {
            transform: scale(0.95);
            transition: transform 0.3s var(--ease-smooth);
        }
        .modal-overlay.active .modal-content {
            transform: scale(1);
        }

        .input-field {
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            border: 1px solid #E2E8F0;
            outline: none;
            transition: all 0.2s;
        }
        .input-field:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

         /* Back Button */
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-sub);
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.6rem 1.2rem;
            border-radius: var(--component-radius);
            background: rgba(255, 255, 255, 0.4);
            border: 1px solid rgba(226, 232, 240, 0.8);
            transition: all var(--transition-speed) var(--ease-smooth);
            text-decoration: none;
            margin-bottom: 2rem;
        }

        .btn-back:hover {
            background: white;
            color: var(--primary);
            border-color: var(--primary);
            transform: translateX(-4px);
        }
    </style>
</head>
<body>

    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    <main class="dashboard-wrapper">

  <a href="/hifz" class="btn-back">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Hifz Management
        </a>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Usthad Management</h1>
                <p class="text-slate-500 font-medium mt-1">Total Registered Usthads: <%= usthads.length %></p>
            </div>
            
            <button onclick="toggleModal('add')" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl font-bold transition-all shadow-lg flex items-center gap-2">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                Create Account
            </button>
        </div>

        <div class="mb-8 flex flex-col md:flex-row gap-4">
            <div class="relative flex-1">
                <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                </span>
                <input type="text" id="searchBox" onkeyup="searchUsthads()" placeholder="Search by name or username..." class="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-4 focus:ring-indigo-50 focus:border-indigo-600 outline-none transition-all">
            </div>
        </div>

        <div class="overflow-x-auto bg-white rounded-2xl border border-slate-100 shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="p-5 text-sm font-bold text-slate-600 uppercase tracking-wider">Usthad Info</th>
                        <th class="p-5 text-sm font-bold text-slate-600 uppercase tracking-wider">Username</th>
                        <th class="p-5 text-sm font-bold text-slate-600 uppercase tracking-wider">Credentials</th>
                        <th class="p-5 text-sm font-bold text-slate-600 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="usthadTableBody">
                    <% if (usthads && usthads.length > 0) { %>
                        <% usthads.forEach(u => { %>
                            <tr class="usthad-row" data-search="<%= u.name.toLowerCase() %> <%= u.username.toLowerCase() %>">
                                <td class="p-5">
                                    <div class="font-bold text-slate-800 text-lg"><%= u.name %></div>
                                    <div class="text-sm text-indigo-600 font-semibold mt-1">📞 <%= u.phone %></div>
                                </td>
                                <td class="p-5">
                                    <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-xs font-bold">@<%= u.username %></span>
                                </td>
                                <td class="p-5">
                                    <div class="flex items-center gap-3">
                                        <span class="pass-container text-slate-400 font-bold" id="pass-<%= u._id %>">••••••••</span>
                                        <button onclick="togglePasswordVisibility('<%= u._id %>', '<%= u.password %>')" class="text-slate-400 hover:text-indigo-600 transition-colors">
                                            <svg id="eye-<%= u._id %>" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                                <td class="p-5 text-right">
                                    <div class="flex justify-end gap-2">
                                        <button onclick="openEditModal('<%= u._id %>', '<%= u.name %>', '<%= u.username %>', '<%= u.phone %>')" class="p-2 hover:bg-indigo-50 text-indigo-600 rounded-lg transition-colors">
                                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        </button>
                                        <button onclick="confirmDelete('<%= u._id %>', '<%= u.name %>')" class="p-2 hover:bg-red-50 text-red-500 rounded-lg transition-colors">
                                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="p-20 text-center text-slate-400 font-medium">No accounts created yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="usthadModal" class="modal-overlay">
        <div class="modal-content bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden p-8">
            <h2 id="modalTitle" class="text-2xl font-extrabold text-slate-900 mb-6">Create Usthad Account</h2>
            <form id="usthadForm" action="/hifz/usthad/add" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Full Name</label>
                    <input type="text" name="name" id="formName" required class="input-field" placeholder="e.g. Mohammed Muzammil">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Username</label>
                        <input type="text" name="username" id="formUser" required class="input-field" placeholder="muzammil_99">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Phone</label>
                        <input type="tel" name="phone" id="formPhone" required pattern="[0-9]{10}" class="input-field" placeholder="9876543210">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Password</label>
                    <input type="text" name="password" id="formPass" required class="input-field" placeholder="Create a secure password">
                </div>
                <div class="flex gap-3 pt-6">
                    <button type="button" onclick="toggleModal()" class="flex-1 py-3 text-slate-500 font-bold hover:bg-slate-50 rounded-xl transition-all">Cancel</button>
                    <button type="submit" class="flex-1 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all">Save Account</button>
                </div>
            </form>
        </div>
    </div>

    <div id="deleteModal" class="modal-overlay">
        <div class="modal-content bg-white w-full max-w-sm rounded-3xl shadow-2xl overflow-hidden p-8 text-center">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </div>
            <h2 class="text-xl font-extrabold text-slate-900 mb-2">Confirm Delete</h2>
            <p class="text-slate-500 mb-8">Are you sure you want to delete <span id="deleteTargetName" class="font-bold text-slate-800"></span>? This action cannot be undone.</p>
            
            <form id="deleteForm" method="POST" class="flex gap-3">
                <button type="button" onclick="closeDeleteModal()" class="flex-1 py-3 text-slate-500 font-bold hover:bg-slate-50 rounded-xl transition-all">Keep it</button>
                <button type="submit" class="flex-1 py-3 bg-red-500 text-white font-bold rounded-xl shadow-lg shadow-red-100 hover:bg-red-600 transition-all">Delete</button>
            </form>
        </div>
    </div>

    <script>
        const modal = document.getElementById('usthadModal');
        const deleteModal = document.getElementById('deleteModal');
        const form = document.getElementById('usthadForm');
        const deleteForm = document.getElementById('deleteForm');

        // Form Modal Logic
        function toggleModal(mode = 'add') {
            if(mode === 'add') {
                document.getElementById('modalTitle').innerText = 'Create Usthad Account';
                form.action = '/hifz/usthad/add';
                form.reset();
            }
            modal.classList.toggle('active');
        }

        function openEditModal(id, name, user, phone) {
            document.getElementById('modalTitle').innerText = 'Update Account';
            form.action = `/hifz/usthad/edit/${id}?_method=PUT`;
            document.getElementById('formName').value = name;
            document.getElementById('formUser').value = user;
            document.getElementById('formPhone').value = phone;
            document.getElementById('formPass').placeholder = "Leave blank to keep current";
            document.getElementById('formPass').required = false; 
            modal.classList.add('active');
        }

        // Custom Delete Logic
        function confirmDelete(id, name) {
            document.getElementById('deleteTargetName').innerText = name;
            deleteForm.action = `/hifz/usthad/delete/${id}`;
            deleteModal.classList.add('active');
        }

        function closeDeleteModal() {
            deleteModal.classList.remove('active');
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target == modal) toggleModal();
            if (event.target == deleteModal) closeDeleteModal();
        }

        function togglePasswordVisibility(id, realPass) {
            const el = document.getElementById(`pass-${id}`);
            const icon = document.getElementById(`eye-${id}`);
            if (el.innerText === '••••••••') {
                el.innerText = realPass;
                el.classList.remove('text-slate-400');
                el.classList.add('text-slate-800');
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
            } else {
                el.innerText = '••••••••';
                el.classList.add('text-slate-400');
                el.classList.remove('text-slate-800');
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
            }
        }

        function searchUsthads() {
            const query = document.getElementById('searchBox').value.toLowerCase();
            const rows = document.querySelectorAll('.usthad-row');
            rows.forEach(row => {
                const text = row.getAttribute('data-search');
                row.style.display = text.includes(query) ? '' : 'none';
            });
        }
    </script>
</body>
</html>