<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hifz Management | Academy</title>
    <!-- Tailwind CSS for utility layout -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Academy Smooth Design Language Implementation */
        :root {
            --primary-accent: #4F46E5;
            --surface-bg: #F8FAFC;
            --glass-card: rgba(255, 255, 255, 0.8);
            --heading-color: #1E293B;
            --subtext-color: #64748B;
            --transition-smooth: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            --shadow-soft: 0 20px 25px 5px rgba(0, 0, 0, 0.05);
        }

        body {
            background-color: var(--surface-bg);
            color: var(--heading-color);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Decorative Background Orbs */
        .orb {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            filter: blur(100px);
            z-index: -1;
            opacity: 0.6;
        }
        .orb-1 {
            background: #E0E7FF; /* Indigo-100 */
            top: -100px;
            right: -100px;
        }
        .orb-2 {
            background: #EFF6FF; /* Blue-50 */
            bottom: -100px;
            left: -100px;
        }

        /* Container & Grid Fluid Scaling */
        .dashboard-container {
            padding: clamp(1.5rem, 5vw, 4rem);
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Glass Card Component */
        .glass-card {
            background: var(--glass-card);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 2rem; /* 32px as per PDF */
            box-shadow: var(--shadow-soft);
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
        }

        .glass-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 40px 5px rgba(0, 0, 0, 0.08);
        }

        /* Button Styling */
        .btn-primary {
            background-color: var(--primary-accent);
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem; /* 12px */
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px; /* Touch target safety */
            transition: var(--transition-smooth);
            width: 100%;
        }

        .btn-primary:active {
            transform: scale(0.98);
        }

        .btn-disabled {
            background-color: #E2E8F0;
            color: #94A3B8;
            cursor: not-allowed;
            pointer-events: none;
        }

        /* Entrance Animations */
        .fade-in-up {
            opacity: 0;
            transform: translateY(15px);
            animation: fadeInUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes fadeInUpAnim {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .stagger-1 { animation-delay: 0.1s; }
        .stagger-2 { animation-delay: 0.2s; }
        .stagger-3 { animation-delay: 0.3s; }

        /* Icon Styling */
        .icon-circle {
            width: 56px;
            height: 56px;
            border-radius: 1rem;
            background: #EEF2FF;
            color: var(--primary-accent);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748B; /* Slate-500 Subtext */
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem; /* 12px Corner Radii */
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid #E2E8F0; /* Print-standard light grey border */
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.btn-back:hover {
    background: #FFFFFF;
    color: #4F46E5; /* Indigo-600 */
    border-color: #4F46E5;
    transform: translateX(-4px); /* Subtle smooth motion */
}

.btn-back:active {
    transform: scale(0.98); /* Interaction scale down */
}
    </style>
</head>
<body>
    <!-- Background Orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <main class="dashboard-container">

        <div class="mb-6 fade-in" style="animation-delay: 0.05s;">
    <a href="/dashboard" class="btn-back">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        <span>Back to Dashboard</span>
    </a>
</div>
        <!-- Header Section -->
        <header class="mb-12 text-center md:text-left fade-in-up">
            <div class="flex items-center justify-center md:justify-start gap-4 mb-3">
                <div class="p-3 bg-indigo-600 rounded-2xl shadow-lg shadow-indigo-200">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                </div>
                <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-800">Hifz Management</h1>
            </div>
            <p class="text-slate-500 text-lg md:max-w-xl">
                Track and manage memorization progress efficiently across all levels of the academy.
            </p>
        </header>

        <!-- Feature Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <!-- Card 1: Progress Tracking -->
            <div class="glass-card p-8 fade-in-up stagger-1">
                <div>
                    <div class="icon-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-6M6 20V10M18 20V4"></path></svg>
                    </div>
                    <h2 class="text-xl font-bold mb-3 text-slate-800">Progress Tracking</h2>
                    <p class="text-slate-500 mb-8 leading-relaxed">
                        View and manage Hifz students' memorization progress including Padam, Sabk Juz, and Murajah.
                    </p>
                </div>
                <a href="/hifz/progress" class="btn-primary">
                    View Hifz Students 
                    <svg class="ml-2" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
            </div>

            <!-- Card 2: Attendance -->
            <div class="glass-card p-8 fade-in-up stagger-2">
                <div>
                    <div class="icon-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                    <h2 class="text-xl font-bold mb-3 text-slate-800">Attendance</h2>
                    <p class="text-slate-500 mb-8 leading-relaxed">
                        Track daily attendance and maintain historical records for every Hifz student automatically.
                    </p>
                </div>
                <button class="btn-primary btn-disabled">
                    Coming Soon
                </button>
            </div>

            <!-- Card 3: Reports -->
            <div class="glass-card p-8 fade-in-up stagger-3">
                <div>
                    <div class="icon-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                    <h2 class="text-xl font-bold mb-3 text-slate-800">Reports</h2>
                    <p class="text-slate-500 mb-8 leading-relaxed">
                        Generate and view structured reports of student progress, performance metrics, and insights.
                    </p>
                </div>
                <button class="btn-primary btn-disabled">
                    Coming Soon
                </button>
            </div>

        </div>

        <!-- Footer Link (Optional) -->
        <footer class="mt-16 pt-8 border-t border-slate-200 text-center text-slate-400 text-sm fade-in-up stagger-3">
            Academy Management System • Design Language v1.0
        </footer>
    </main>

    <script>
        // Simple script to handle visual feedback on touch/click
        document.querySelectorAll('.btn-primary:not(.btn-disabled)').forEach(button => {
            button.addEventListener('mousedown', () => {
                button.style.transform = 'scale(0.98)';
            });
            button.addEventListener('mouseup', () => {
                button.style.transform = 'scale(1)';
            });
            button.addEventListener('mouseleave', () => {
                button.style.transform = 'scale(1)';
            });
        });
    </script>
</body>
</html>